{
  "name": "vue3-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.ts,js,.tsx,.jsx --fix",
    "lint:staged": "lint-staged",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{vue,ts,js,tsx,jsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "element-plus": "^2.13.6",
    "vue": "^3.5.25",
    "vue-eslint-parser": "^10.4.0"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/tsconfig": "^0.8.1",
    "commitlint": "^20.5.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^7.3.1",
    "vue-router": "^5.0.3",
    "vue-tsc": "^3.1.5"
  }
}
